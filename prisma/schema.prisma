// ZapatoFlex - Modelo de datos
// Base de datos SQLite para prototipo (producción: PostgreSQL en Vercel/Turso)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Rol {
  USUARIO
  ADMIN
}

enum EstadoPedido {
  PENDIENTE
  CONFIRMADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  SIMULADO
  APROBADO
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String
  passwordHash String
  rol       Rol      @default(USUARIO)
  createdAt DateTime @default(now())
  carrito   Carrito?
  pedidos   Pedido[]
}

// --- Catálogos ---

model Categoria {
  id            String         @id @default(cuid())
  nombre        String         @unique
  productos     Producto[]
  subcategorias Subcategoria[]
}

model Subcategoria {
  id          String     @id @default(cuid())
  nombre      String
  categoriaId String
  categoria   Categoria  @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  productos   Producto[]

  @@unique([nombre, categoriaId])
}

model Marca {
  id        String     @id @default(cuid())
  nombre    String     @unique
  productos Producto[]
}

model Color {
  id        String     @id @default(cuid())
  nombre    String     @unique
  productos Producto[]
}

model Talla {
  id        String          @id @default(cuid())
  valor     String          @unique
  variantes ProductoTalla[]
}

model Genero {
  id        String     @id @default(cuid())
  nombre    String     @unique
  productos Producto[]
}

// --- Producto ---

model Producto {
  id          String            @id @default(cuid())
  nombre      String
  descripcion String?
  precio      Float
  categoriaId String?
  categoria   Categoria?        @relation(fields: [categoriaId], references: [id])
  subcategoriaId String?
  subcategoria   Subcategoria?  @relation(fields: [subcategoriaId], references: [id])
  marcaId     String
  marca       Marca             @relation(fields: [marcaId], references: [id])
  colorId     String
  color       Color             @relation(fields: [colorId], references: [id])
  generoId    String?
  genero      Genero?           @relation(fields: [generoId], references: [id])
  createdAt   DateTime          @default(now())
  imagenes    ImagenProducto[]
  variantes   ProductoTalla[]
  lineasCarrito LineaCarrito[]
  lineasPedido  LineaPedido[]
}

model ProductoTalla {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  tallaId    String
  talla      Talla    @relation(fields: [tallaId], references: [id])
  stock      Int      @default(0)

  @@unique([productoId, tallaId])
}

model ImagenProducto {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  url        String
  orden      Int      @default(0)
  createdAt  DateTime @default(now())
}

// --- Carrito ---

model Carrito {
  id        String        @id @default(cuid())
  usuarioId String        @unique
  usuario   Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  items     LineaCarrito[]
}

model LineaCarrito {
  id         String   @id @default(cuid())
  carritoId  String
  carrito    Carrito  @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  cantidad   Int      @default(1)
  talla      String?
}

// --- Pedido ---

model Pedido {
  id          String      @id @default(cuid())
  usuarioId   String
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  estado      EstadoPedido @default(PENDIENTE)
  total       Float
  metodoPago  String      @default("CONTRAENTREGA")
  createdAt   DateTime    @default(now())
  lineas      LineaPedido[]
  pago        Pago?
}

model LineaPedido {
  id             String   @id @default(cuid())
  pedidoId       String
  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId     String
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Float
  talla          String?
}

model Pago {
  id        String     @id @default(cuid())
  pedidoId  String     @unique
  pedido    Pedido     @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  metodo    String     @default("CONTRAENTREGA")
  estado    EstadoPago @default(SIMULADO)
  createdAt DateTime   @default(now())
}

// --- Configuración de sitio ---

model ConfiguracionSitio {
  id              String   @id @default("default")
  heroTitulo      String   @default("Tu estilo, tu comodidad")
  heroDescripcion String   @default("Descubre calzado deportivo, casual y formal con envios a todo Colombia.")
  colorPrimario   String   @default("#6366f1")
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
